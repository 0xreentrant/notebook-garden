{
  "manifest_version": 3,
  "name": "notebook-garden NotebookLM",
  "version": "0.1.0",
  "description": "Creates a NotebookLM notebook per video when called by notebook-garden",
  "key": "",
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://notebooklm.google.com/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:*/*",
      "http://127.0.0.1:*/*"
    ]
  }
}
